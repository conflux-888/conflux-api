PORT=8080

MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=conflux

JWT_SECRET=change-me-in-production

SYNC_INTERVAL_MINUTES=15

GEMINI_API_KEY=
SUMMARY_CHECK_INTERVAL_MIN=30
SUMMARY_BACKFILL_DAYS=7

CORS_ALLOW_LOCALHOST=false
ADMIN_UI_ENABLED=true
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

LOG_LEVEL=info

# APNs (iOS Push Notifications) — leave APNS_KEY_PATH empty to disable push.
# Path to .p8 auth key downloaded from developer.apple.com.
APNS_KEY_PATH=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.conflux.app
# false = sandbox (Xcode/TestFlight dev builds), true = production (App Store / TestFlight prod)
APNS_PRODUCTION=false
